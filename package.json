{
  "name": "content-pulse",
  "version": "0.1.0",
  "private": true,
  "description": "Plan, score, and evolve content ideas that actually support the business.",
  "type": "module",
  "scripts": {
    "start": "python3 -m http.server 8000",
    "example:score": "node scripts/example-score.mjs",
    "validate:board": "node scripts/validate-board.mjs",
    "verify": "node scripts/verify.mjs",
    "test:scoring": "node --test scripts/scoring.test.mjs",
    "test:board": "node --test scripts/validate-board.test.mjs",
    "test": "npm run verify && npm run test:scoring && npm run test:board"
  },
  "license": "MIT"
}
